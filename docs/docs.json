{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "PMXT",
  "logo": {
    "light": "/logo-light.png",
    "dark": "/logo-dark.png"
  },
  "favicon": "/favicon.png",
  "colors": {
    "primary": "#0B0B0B",
    "light": "#FAFAFA",
    "dark": "#0B0B0B"
  },
  "api": {
    "examples": {
      "languages": [
        "curl",
        "python",
        "javascript",
        "go",
        "java"
      ]
    }
  },
  "contextual": {
    "options": [
      "copy",
      "claude",
      "chatgpt",
      "cursor"
    ],
    "display": "header"
  },
  "navbar": {
    "links": [
      {
        "label": "Dashboard",
        "href": "https://pmxt.dev/dashboard"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get API Key",
      "href": "https://pmxt.dev/dashboard"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "quickstart",
              "authentication",
              "mcp",
              "security",
              "rate-limits"
            ]
          },
          {
            "group": "Concepts",
            "pages": [
              "concepts/unified-schema",
              "concepts/catalog-vs-live",
              "concepts/venues"
            ]
          },
          {
            "group": "SDK",
            "pages": [
              "sdk/server"
            ]
          }
        ]
      },
      {
        "tab": "Router",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "router/overview"
            ]
          },
          {
            "group": "Search",
            "pages": [
              "router/events",
              "router/markets"
            ]
          },
          {
            "group": "Analyze",
            "pages": [
              "router/event-matching",
              "router/matching",
              "router/prices"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/overview"
            ]
          },
          {
            "group": "System",
            "openapi": "api-reference/openapi.json",
            "pages": [
              "GET /health",
              "POST /api/{exchange}/loadMarkets",
              "POST /api/{exchange}/close"
            ]
          },
          {
            "group": "Events & Markets",
            "openapi": "api-reference/openapi.json",
            "pages": [
              "GET /api/{exchange}/fetchEvents",
              "GET /api/{exchange}/fetchEvent",
              "GET /api/{exchange}/fetchMarkets",
              "GET /api/{exchange}/fetchMarketsPaginated",
              "GET /api/{exchange}/fetchMarket"
            ]
          },
          {
            "group": "Cross-Venue",
            "openapi": "api-reference/openapi.json",
            "pages": [
              "GET /api/{exchange}/fetchEventMatches",
              "GET /api/{exchange}/fetchMarketMatches",
              "POST /api/{exchange}/compareMarketPrices",
              "GET /api/{exchange}/fetchHedges",
              "GET /api/{exchange}/fetchArbitrage"
            ]
          },
          {
            "group": "Order Book & Trades",
            "openapi": "api-reference/openapi.json",
            "pages": [
              "GET /api/{exchange}/fetchOHLCV",
              "GET /api/{exchange}/fetchOrderBook",
              "GET /api/{exchange}/fetchTrades",
              "POST /api/{exchange}/getExecutionPrice",
              "POST /api/{exchange}/getExecutionPriceDetailed"
            ]
          },
          {
            "group": "Trading",
            "openapi": "api-reference/openapi.json",
            "pages": [
              "POST /api/{exchange}/createOrder",
              "POST /api/{exchange}/buildOrder",
              "POST /api/{exchange}/submitOrder",
              "POST /api/{exchange}/cancelOrder"
            ]
          },
          {
            "group": "Orders & Positions",
            "openapi": "api-reference/openapi.json",
            "pages": [
              "GET /api/{exchange}/fetchOrder",
              "GET /api/{exchange}/fetchOpenOrders",
              "GET /api/{exchange}/fetchMyTrades",
              "GET /api/{exchange}/fetchClosedOrders",
              "GET /api/{exchange}/fetchAllOrders",
              "GET /api/{exchange}/fetchPositions",
              "GET /api/{exchange}/fetchBalance"
            ]
          },
          {
            "group": "Realtime",
            "openapi": "api-reference/openapi.json",
            "pages": [
              "POST /api/{exchange}/watchOrderBook",
              "POST /api/{exchange}/unwatchOrderBook",
              "POST /api/{exchange}/watchTrades",
              "POST /api/{exchange}/watchAddress",
              "POST /api/{exchange}/unwatchAddress"
            ]
          },
          {
            "group": "Other",
            "openapi": "api-reference/openapi.json",
            "pages": [
              "GET /api/{exchange}/fetchEventsPaginated"
            ]
          },
          {
            "group": "Enterprise",
            "openapi": "api-reference/openapi-hosted.json",
            "pages": [
              "POST /v0/sql"
            ]
          }
        ]
      }
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/pmxt-dev/pmxt"
    }
  }
}
